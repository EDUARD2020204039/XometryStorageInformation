# Shared app configuration
DATABASE_URL=sqlite:////app/data/xometry_offers.db
GLITCHTIP_DSN=
SENTRY_DSN=
APP_ENV=production

# Xometry bot credentials
XOMETRY_EMAIL=
XOMETRY_PASSWORD=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot -> app sync
BACKEND_ENABLED=true
BACKEND_URL=http://xometry-app:10000
BACKEND_API_KEY=
BACKEND_RESEND_EXISTING=false
BACKEND_MAX_OFFERS_PER_RUN=10
AGENT_URL=http://xometryanaliza:4468
AGENT_PUBLIC_URL=http://127.0.0.1:4468
AGENT_TIMEOUT=10
OFERTARE_AUTOMATA_URL=http://127.0.0.1:8585
OFERTARE_API_TOKEN=
OFERTARE_AUTOMATA_ROOT=C:\path\to\Ofertare-Automata\XometryAuto
OFERTARE_AUTOMATA_CONNECT_TIMEOUT=10
OFERTARE_AUTOMATA_READ_TIMEOUT=1800
GEO_SFTP_HOST=
GEO_SFTP_PORT=22
GEO_SFTP_USER=
GEO_SFTP_KEY_PATH=/app/data/ssh/id_ed25519
SHEET_AGENT_RETRY_SECONDS=3600
TELEGRAM_SHEET_START_LOGS=false
TELEGRAM_SHEET_FAILURE_LOGS=false
TELEGRAM_GEO_LOGS=false

# Bot runtime
CHECK_INTERVAL=120
ORDERS_SYNC_ENABLED=true
ORDERS_SYNC_INTERVAL=600
ORDERS_SYNC_MAX_ORDERS=0
ORDERS_SCROLL_ROUNDS=200
ORDERS_PAGINATION_MAX_PAGES=0
ORDERS_STOP_AFTER_EMPTY_PAGES=3
ORDERS_PROCESS_ONLY_NEW=true
ORDERS_SYNC_LOCK_MAX_AGE=21600
BACKEND_ORDERS_BATCH_SIZE=200
BACKEND_ORDERS_TIMEOUT=180
BACKEND_ORDERS_RETRY=2

# Dosare / Odoo
# Completeaza aici dupa ce ai user/parola; codul nu pune credentiale in extensie.
DOSAR_API_URL=
DOSAR_API_TOKEN=
DOSAR_FOLDER_ENABLED=true
ODOO_BASE_URL=
ODOO_DB=
ODOO_LOGIN=
ODOO_PASSWORD=
ODOO_ACTION_ID=997
# Dupa ce studiem formularul autentificat, punem modelul si campurile reale aici.
ODOO_DOSAR_MODEL=
ODOO_DOSAR_NAME_FIELD=name
ODOO_DOSAR_OFFER_FIELD=
ODOO_DOSAR_JOB_FIELD=
ODOO_DOSAR_PARTS_FIELD=
ODOO_DOSAR_SOURCE_FIELD=
ODOO_DOSAR_URL_FIELD=
ODOO_DOSAR_REQUIRED=true
